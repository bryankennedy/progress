# Template for local development secrets. Worker bindings read local secrets
# from .dev.vars (the Wrangler/Miniflare convention) — copy this file to
# .dev.vars and fill in real values. Both .env and .dev.vars are gitignored;
# production secrets go in Cloudflare via `wrangler secret put <KEY>`.

# Shared secret for verifying GitHub webhook signatures (X-Hub-Signature-256)
GITHUB_WEBHOOK_SECRET=
